# Environment Variables

# Server Configuration
PORT=5000

# OpenAI API Key (optional - the app works without it using mock responses)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# MongoDB Configuration (optional - the app works without it using in-memory storage)
# For local development: mongodb://localhost:27017/ai-study-planner
# For MongoDB Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ai-study-planner
MONGODB_URI=mongodb://localhost:27017/ai-study-planner
